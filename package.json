{
  "name": "baraka-grill",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-next.mjs",
    "dev": "next dev -p 3002",
    "dev:fresh": "node scripts/clean-next.mjs && next dev -p 3002",
    "build": "node scripts/with-database-url.mjs npx prisma generate && node scripts/with-database-url.mjs npx prisma migrate deploy && node scripts/with-database-url.mjs npx tsx scripts/ensure-admin.ts && node scripts/with-database-url.mjs npx next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "db:generate": "node scripts/with-database-url.mjs npx prisma generate",
    "prisma:generate": "node scripts/with-database-url.mjs npx prisma generate",
    "db:push": "node scripts/with-database-url.mjs npx prisma db push",
    "db:migrate": "node scripts/with-database-url.mjs npx prisma migrate deploy",
    "db:seed": "node scripts/with-database-url.mjs npx prisma db seed",
    "admin:ensure": "node scripts/with-database-url.mjs npx tsx scripts/ensure-admin.ts",
    "admin:seed": "node scripts/with-database-url.mjs npx tsx scripts/ensure-admin.ts",
    "images:seed": "node scripts/download-menu-images.mjs",
    "postinstall": "node scripts/with-database-url.mjs npx prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "15.5.15",
    "nodemailer": "^8.0.7",
    "prisma": "5.22.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tsx": "^4.21.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@netlify/plugin-nextjs": "^5.15.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
